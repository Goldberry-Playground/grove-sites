# syntax=docker/dockerfile:1.7

# Multi-stage build for the Goldberry Next.js storefront.
#
# Build context expected: grove-sites/ (the monorepo root), NOT apps/goldberry.
# This is so we can install workspace dependencies and trace the Next standalone
# output against the full monorepo. From the Makefile:
#   docker build -f apps/goldberry/Dockerfile grove-sites/
#
# Output: a ~250MB image running `node server.js` on port 3001.

ARG NODE_VERSION=22-alpine

# ── 1. install dependencies (with pnpm fetch + frozen-lockfile) ───────────
FROM node:${NODE_VERSION} AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /workspace
RUN corepack enable

# Copy only the manifests so this layer caches across source changes.
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json .npmrc ./
COPY apps/goldberry/package.json apps/goldberry/
COPY packages/ui/package.json packages/ui/
COPY packages/odoo-client/package.json packages/odoo-client/
COPY packages/ghost-client/package.json packages/ghost-client/
COPY packages/config/package.json packages/config/
COPY packages/analytics/package.json packages/analytics/

RUN pnpm install --frozen-lockfile

# ── 2. build the standalone Next.js bundle ───────────────────────────────
FROM node:${NODE_VERSION} AS builder
WORKDIR /workspace
RUN corepack enable

# Bring forward the resolved node_modules (top-level + each workspace's).
COPY --from=deps /workspace/node_modules ./node_modules
COPY --from=deps /workspace/apps/goldberry/node_modules ./apps/goldberry/node_modules
COPY --from=deps /workspace/packages/ui/node_modules ./packages/ui/node_modules
COPY --from=deps /workspace/packages/odoo-client/node_modules ./packages/odoo-client/node_modules
COPY --from=deps /workspace/packages/ghost-client/node_modules ./packages/ghost-client/node_modules
COPY --from=deps /workspace/packages/config/node_modules ./packages/config/node_modules
COPY --from=deps /workspace/packages/analytics/node_modules ./packages/analytics/node_modules

# Then copy the rest of the source.
COPY . .

ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm --filter @grove/goldberry build

# ── 3. minimal runtime image ─────────────────────────────────────────────
FROM node:${NODE_VERSION} AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3001
ENV HOSTNAME=0.0.0.0

# Run as non-root so a compromised process can't poke around the container.
RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 nextjs

# Copy the standalone server (includes node_modules) + public assets + the
# static build (.next/static must live alongside server.js for Next to find it).
COPY --from=builder --chown=nextjs:nodejs /workspace/apps/goldberry/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /workspace/apps/goldberry/.next/static ./apps/goldberry/.next/static
COPY --from=builder --chown=nextjs:nodejs /workspace/apps/goldberry/public ./apps/goldberry/public

USER nextjs
EXPOSE 3001

# server.js is generated by Next when output: "standalone" is set.
CMD ["node", "apps/goldberry/server.js"]
