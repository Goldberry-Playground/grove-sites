# Goldberry storefront — local dev env file.
# Copy to .env.local and fill in values. Do NOT commit .env.local.

# ── Odoo backend ─────────────────────────────────────────────────────────
# Sent as the X-Grove-Tenant header — controls multi-tenant company scoping
# in grove_headless. Must match the website name configured in Odoo (see
# grove_headless/data/grove_companies.xml).
TENANT_ID=goldberry

# Local: http://localhost:8069 (from `make stack-up`)
# Sandbox/prod: set to the deployed Odoo URL.
ODOO_URL=http://localhost:8069

# Optional. Leave blank for the public storefront endpoints (products, cart,
# orders) — they use auth=public and don't need a key. Set to a real key if
# you wire up authenticated endpoints later.
ODOO_API_KEY=

# ── Ghost CMS ────────────────────────────────────────────────────────────
# Local: http://localhost:2368
# Sandbox/prod: set to the deployed Ghost URL.
GHOST_URL=http://localhost:2368

# Generate via `make ghost-setup-goldberry` (requires GHOST_ADMIN_PASSWORD env).
# That script creates a Custom Integration in Ghost and prints the key.
# Without it the /blog page will return 401 from Ghost.
GHOST_CONTENT_KEY=
